variable "automation_credentials" {
  description = <<EOT
Map of automation_credentials, attributes below
Required:
    - automation_account_name
    - name
    - password
    - password_key_vault_id (alternative to password - read from Key Vault instead)
    - password_key_vault_secret_name (alternative to password - read from Key Vault instead)
    - resource_group_name
    - username
Optional:
    - description
EOT

